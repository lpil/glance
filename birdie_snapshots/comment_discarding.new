    Comment(" four", Span(106, 113)),
  ],
  [],
  [
    Definition(
      [],
      CustomType(
        Span(0, 117),
        "Spooky",
        Public,
        False,
        ["t", "u"],
        [Variant("Spooky", [], [])],
      ),
    ),
  ],
  [],
  [],
